/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
.nyc_output

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# PWA / Serwist files
public/sw*
public/swe-worker*

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini

# Python
__pycache__/
*.py[cod]
*$py.class
venv/

# Cursor
.cursor/

# Bun
bun.lock

# Certificates
certs/

# Review gate script
final_review_gate.py

# Test scripts with sensitive data
test-*.js
